<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/Toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:padding="0dp"
        app:contentInsetEnd="0dp"
        app:contentInsetStart="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/Toolbar.TitleText"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="100dp"
                tools:text="fdkjsgsnkdfg jkdfgnsdkjgn dfgn sdkjgnsdfk jgnsdfgn sdn"
                android:text="@string/kido_list" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusableInTouchMode="true"
                android:hint="@string/min"
                android:textColorHint="@color/yellow"
                tools:visibility="visible">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/user_time"
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:digits="0123456789"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:inputType="datetime"
                    android:maxLength="2"
                    android:maxLines="1"
                    android:paddingBottom="14dp"
                    android:textColor="@color/white"
                    android:textSize="21sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/chronometer"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:textColor="@color/white"
                android:textSize="21sp"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:visibility="invisible"
                tools:visibility="invisible"
                tools:text="00:00" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp">

            <Button
                android:id="@+id/start"
                style="@style/ButtonChronometer"
                android:layout_marginEnd="10dp"
                android:text="@string/start" />

<!--            <Button-->
<!--                android:id="@+id/stop"-->
<!--                style="@style/ButtonChronometer"-->
<!--                android:layout_marginEnd="10dp"-->
<!--                android:layout_marginStart="10dp"-->
<!--                android:text="@string/stop" />-->

            <Button
                android:id="@+id/reset"
                style="@style/ButtonChronometer"
                android:text="@string/reset" />
        </LinearLayout>

        <View
            style="@style/AppTheme.HorizontalViewDivider"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/activity_to_do"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_list_kido"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:listitem="@layout/item_kido" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/fab_margin"
            android:src="@drawable/ic_add"
            app:rippleColor="@color/primary" />

        <include
            android:id="@+id/list_kido_empty"
            layout="@layout/view_kido_empty"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>